{
  "name": "hometech-site",
  "version": "1.0.0",
  "description": "Site da Nano Franquia Hometech",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
    "build:js": "babel app.jsx --out-file dist/app.js --presets=@babel/preset-env,@babel/preset-react",
    "build": "npm run build:css && npm run build:js",
    "dev": "tailwindcss -i ./src/input.css -o ./dist/output.css --watch",
    "dev:js": "babel app.jsx --out-file dist/app.js --presets=@babel/preset-env,@babel/preset-react --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romulovander/hometech-site.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/romulovander/hometech-site/issues"
  },
  "homepage": "https://github.com/romulovander/hometech-site#readme",
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/core": "^8.0.1",
    "@babel/plugin-transform-react-jsx": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
