{
  "presets": [
    ["@babel/preset-env", { 
      "modules": "commonjs",
      "targets": { "browsers": ["> 1%", "last 2 versions", "not dead"] }
    }],
    ["@babel/preset-react", { 
      "runtime": "classic",
      "development": false,
      "throwIfNamespace": false
    }]
  ],
  "plugins": [
    ["@babel/plugin-transform-react-jsx", { 
      "runtime": "classic",
      "useBuiltIns": true
    }]
  ]
}